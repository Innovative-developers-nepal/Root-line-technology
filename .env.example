# Rootline docker stack — runtime config
# Copy to .env and edit before `docker compose up`.

# ─── Required ───────────────────────────────────────────────────────────
# Public host browsers will hit. NO trailing slash.
#   Local dev:     http://localhost
#   AWS EC2 IP:    http://3.123.45.67
#   AWS + port:    http://3.123.45.67:80      (omit :80 if standard)
#   Domain (TLS):  https://rootline.tech
PUBLIC_HOST=http://localhost

# Webhook secret — must match REVALIDATE_SECRET in apps/api/.env.docker
# Generate: openssl rand -base64 32
REVALIDATE_SECRET=changeme_generate_with_openssl

# ─── Optional ──────────────────────────────────────────────────────────
# Nginx host port (default 80; use 8080 if 80 is busy on dev box)
NGINX_PORT=80

# PostHog (leave blank to disable analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Map / geo (footer + structured data)
GEO_LAT=27.7172
GEO_LNG=85.3240
