# Rootline API — runtime configuration
# Copy to .env.docker for Docker Compose, or use directly for local dev.

PORT=5000
NODE_ENV=production

# PostgreSQL — DATABASE_URL is set via docker-compose environment block
# (supports ${POSTGRES_PASSWORD} interpolation from root .env)

# CORS — comma-separated (overridden by docker-compose environment)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Better-Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me_with_32_plus_random_chars
BETTER_AUTH_URL=http://localhost:5000

# Legacy JWT (kept until Better-Auth swap)
JWT_PRIVATE_KEY=replace_me
JWT_EXPIRES_IN=15m
JWT_SECRET=replace_me

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/callback/google

# Frontend URLs (overridden by docker-compose environment)
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Revalidate webhook (overridden by docker-compose environment)
REVALIDATE_SECRET=replace_me

# SMTP (optional — leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Rootline
SMTP_FROM_EMAIL=no-reply@rootline.tech
CONTACT_NOTIFY_EMAIL=
