# Rootline API
PORT=5000
NODE_ENV=development
BASE_URL=http://localhost:5000

# SQLite database
DATABASE_URL=file:../../db/dev.db

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Better-Auth (scaffolded, not yet wired)
BETTER_AUTH_SECRET=replace_me_with_32_plus_random_chars
BETTER_AUTH_URL=http://localhost:5000

# Legacy JWT (kept until Better-Auth swap)
JWT_PRIVATE_KEY=your_private_key_here
JWT_EXPIRES_IN=15m
JWT_SECRET=your_jwt_secret_here

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/callback/google

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Revalidate webhook (shared secret with Next /api/revalidate)
REVALIDATE_SECRET=replace_me_with_random_string

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user@gmail.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM_NAME=Rootline
SMTP_FROM_EMAIL=no-reply@rootline.tech
CONTACT_NOTIFY_EMAIL=team@rootline.tech
