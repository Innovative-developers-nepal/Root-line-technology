{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "types": ["node"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true
  },
   "include": ["src/**/*", "prisma/**/*", "*.ts"],
  "exclude": ["node_modules", "dist"]
}