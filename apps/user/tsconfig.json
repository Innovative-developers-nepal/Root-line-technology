{
  "extends": "@rootline/tsconfig/nextjs.json",
  "compilerOptions": {
    // "baseUrl": ".",
    "moduleResolution": "bundler",
    "types": ["node", "next", "next/types/global"],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-build/types/**/*.ts",
    "./app/golobals.css"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
